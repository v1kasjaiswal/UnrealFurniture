<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/wishCardView"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_marginTop="7dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" >

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/wishMainImage"
                android:layout_width="120dp"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/blank"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />


            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/wishName"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:ellipsize="marquee"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="10dp"
                android:singleLine="true"
                android:fontFamily="@font/satoshibold"
                android:marqueeRepeatLimit="marquee_forever"
                android:text="Bed and Sofa Set"
                android:textColor="@color/dark"
                android:textSize="18sp"
                app:layout_constraintStart_toEndOf="@+id/wishMainImage"
                app:layout_constraintTop_toTopOf="parent" />

            <RatingBar
                android:id="@+id/wishRating"
                style="@style/Widget.AppCompat.RatingBar.Small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:rating="4.5"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="3dp"
                android:stepSize="0.5"
                app:layout_constraintStart_toEndOf="@+id/wishMainImage"
                app:layout_constraintTop_toBottomOf="@+id/wishName" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/wishRatingCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/satoshibold"
                android:text="(17,456)"
                android:layout_marginLeft="10dp"
                android:textColor="@color/dark"
                app:layout_constraintStart_toEndOf="@+id/wishRating"
                app:layout_constraintTop_toBottomOf="@+id/wishName" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/wishPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/satoshibold"
                android:text="₹17,958"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="5dp"
                android:textColor="@color/light"
                android:textSize="15sp"
                app:layout_constraintStart_toEndOf="@+id/wishMainImage"
                app:layout_constraintTop_toBottomOf="@+id/wishRating" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/wishDiscountedPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/satoshibold"
                android:text="₹15000"
                android:textColor="@color/darker"
                android:textSize="15sp"
                app:layout_constraintStart_toEndOf="@+id/wishPrice"
                app:layout_constraintTop_toBottomOf="@+id/wishRatingCount" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/wishMainImage">


                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/wishDiscount"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="7dp"
                    android:text="22.22% ↓"
                    android:textColor="@color/dark"
                    android:textSize="11sp"
                    app:fontFamily="@font/satoshibold" />

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/wishRemove"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="20dp"
                android:src="@drawable/delete"
                android:padding="5dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />


        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
