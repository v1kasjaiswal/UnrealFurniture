<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="7dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginTop="10dp"
            android:layout_marginLeft="10dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/blank"
                android:scaleType="centerCrop" />

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="70dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="15dp"
            android:ellipsize="marquee"
            android:fontFamily="@font/satoshibold"
            android:marqueeRepeatLimit="marquee_forever"
            android:singleLine="true"
            android:text="This is Name of the User"
            android:textColor="@color/dark"
            android:textSize="15sp" />

        <RatingBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.AppCompat.RatingBar.Small"
            android:layout_marginLeft="70dp"
            android:layout_marginTop="35dp"
            android:rating="4.5"
            android:stepSize="0.5" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="29th May 2021"
            android:layout_marginRight="20dp"
            android:layout_marginTop="35dp"
            android:fontFamily="@font/satoshibold"
            android:textColor="@color/light"
            android:textSize="13sp" />

        <com.colormoon.readmoretextview.ReadMoreTextView
            android:id="@+id/readMoreTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:layout_marginTop="60dp"
            app:colorClickableText="@color/darker"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/satoshibold"
            android:textColor="@color/dark"
            android:textSize="15sp"
            android:text="Lorem ipsum dolor sit amet. Et quas recusandae ut odio ipsam est consequuntur voluptate. Et laudantium perspiciatis id unde voluptatem vel quas veniam aut rerum nesciunt quo natus dignissimos eum perspiciatis dicta."/>

    </com.google.android.material.card.MaterialCardView>



</androidx.constraintlayout.widget.ConstraintLayout>